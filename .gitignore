# Terraform state files
*.tfstate
*.tfstate.*

# Terraform cache
.terraform/

# Plan files
*.tfplan

# Variable files with secrets
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log

# Sensitive files
terraform.rc
.terraformrc

# Terraform lock file (optional)
.terraform.lock.hcl